<Window x:Class="ARCYN.UI.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ARCYN Setup"
        Width="700"
        Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#FF0A0A0A"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource UIFont}">
    <Window.Resources>
        <Style x:Key="StepTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="StepDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="WizInput" TargetType="TextBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="#E6080808"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrightBrush}"/>
            <Setter Property="Height" Value="28"/>
        </Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#18000000"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30D64545"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#50D64545"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Foreground" Value="#0A0A0A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{StaticResource AccentBrightBrush}"
                                BorderThickness="0"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFC0C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFE0E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,4,3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="Background" Value="#14000000"/>
        </Style>
    </Window.Resources>

<Border CornerRadius="9"
        Background="#0A0A0A"
        BorderThickness="1"
        BorderBrush="{StaticResource BorderGlowBrush}"
        Effect="{StaticResource GlowAccent}" Padding="16">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="#12000000"
                    CornerRadius="8,8,0,0"
                    Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="5" Height="5"
                             Fill="{StaticResource AccentBrightBrush}"
                             VerticalAlignment="Center"
                             Effect="{StaticResource GlowAccentSharp}"/>
                    <TextBlock Grid.Column="1"
                               Text="ARCYN SETUP"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2"
                               x:Name="StepCounter"
                               FontSize="8"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,12,20,0">

                <!-- Step 1: Welcome -->
                <Grid x:Name="StepWelcome">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource StepTitle}" Text="WELCOME TO ARCYN"/>
                    <TextBlock Grid.Row="1" Style="{StaticResource StepDesc}"
                               Text="Tactical workspace launcher. Configure your modes to launch apps, websites, and folders with a single click."/>
                    <Border Grid.Row="2"
                            Background="#0A000000"
                            CornerRadius="3"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            Padding="12,10"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="!"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrightBrush}"
                                       VerticalAlignment="Top"
                                       Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                       TextWrapping="Wrap">
                                <Run Text="Create workspaces (modes)"/> <LineBreak/>
                                <Run Text="Each mode opens your apps, sites, and folders together"/> <LineBreak/>
                                <Run Text="Press a number key to launch — fast"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Style="{StaticResource ChipStyle}" Padding="8,3">
                            <TextBlock Text=" .NET 8" FontSize="8" Foreground="{StaticResource TextMutedBrush}"/>
                        </Border>
                        <Border Style="{StaticResource ChipStyle}" Padding="8,3">
                            <TextBlock Text=" Windows" FontSize="8" Foreground="{StaticResource TextMutedBrush}"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Step 2: Create Mode -->
                <Grid x:Name="StepMode" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource StepTitle}" Text="NAME YOUR WORKSPACE"/>
                    <TextBlock Grid.Row="1" Style="{StaticResource StepDesc}"
                               Text="Each mode is a workspace. Give it a name and description."/>
                    <TextBlock Grid.Row="2" Style="{StaticResource FieldLabel}" Text="NAME"/>
                    <TextBox Grid.Row="3" x:Name="ModeNameInput" Style="{StaticResource WizInput}"
                            />
                    <TextBlock Grid.Row="4" Style="{StaticResource FieldLabel}" Text="DESCRIPTION"/>
                    <TextBox Grid.Row="5" x:Name="ModeDescInput" Style="{StaticResource WizInput}"
                            />
                    <Grid Grid.Row="6" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource FieldLabel}" Text="ACCENT COLOR"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                            <RadioButton x:Name="ColorRed" GroupName="Accent" IsChecked="True"
                                         ToolTip="Classic Red">
                                <RadioButton.Content>
                                    <Ellipse Width="20" Height="20" Fill="#D64545" Margin="2"/>
                                </RadioButton.Content>
                            </RadioButton>
                            <RadioButton x:Name="ColorBlue" GroupName="Accent" Margin="8,0,0,0"
                                         ToolTip="Cyber Blue">
                                <RadioButton.Content>
                                    <Ellipse Width="20" Height="20" Fill="#4580D6" Margin="2"/>
                                </RadioButton.Content>
                            </RadioButton>
                            <RadioButton x:Name="ColorGreen" GroupName="Accent" Margin="8,0,0,0"
                                         ToolTip="Matrix Green">
                                <RadioButton.Content>
                                    <Ellipse Width="20" Height="20" Fill="#45D680" Margin="2"/>
                                </RadioButton.Content>
                            </RadioButton>
                            <RadioButton x:Name="ColorOrange" GroupName="Accent" Margin="8,0,0,0"
                                         ToolTip="Phosphor Orange">
                                <RadioButton.Content>
                                    <Ellipse Width="20" Height="20" Fill="#D6A045" Margin="2"/>
                                </RadioButton.Content>
                            </RadioButton>
                            <RadioButton x:Name="ColorPurple" GroupName="Accent" Margin="8,0,0,0"
                                         ToolTip="Void Purple">
                                <RadioButton.Content>
                                    <Ellipse Width="20" Height="20" Fill="#A045D6" Margin="2"/>
                                </RadioButton.Content>
                            </RadioButton>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Step 3: Apps -->
                <Grid x:Name="StepApps" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource StepTitle}" Text="ADD APPLICATIONS"/>
                    <TextBlock Grid.Row="1" Style="{StaticResource StepDesc}"
                               Text="Pick apps to launch with this mode. You can add more later."/>
                    <Border Grid.Row="2"
                            Background="#0A000000"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            CornerRadius="3"
                            Padding="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                            <ItemsControl x:Name="AppsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ChipStyle}" Margin="0,0,0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Content="X"
                                                        FontSize="7"
                                                        Foreground="{StaticResource AccentLightBrush}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="4,0"
                                                        Cursor="Hand"
                                                        Tag="{Binding}"
                                                        Click="RemoveApp_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Style="{StaticResource NavButton}"
                                Content="+ Browse"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Click="AddApp_Click"/>
                        <TextBox x:Name="AppQuickInput"
                                 Style="{StaticResource WizInput}"
                                 Width="200"
                                 Margin="8,0,0,0"
                                />
                        <Button Style="{StaticResource NavButton}"
                                Content="+ Add"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Margin="4,0,0,0"
                                Click="AddAppQuick_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Step 4: Folders -->
                <Grid x:Name="StepFolders" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource StepTitle}" Text="ADD FOLDERS"/>
                    <TextBlock Grid.Row="1" Style="{StaticResource StepDesc}"
                               Text="Add folders to open in Explorer when this mode launches."/>
                    <Border Grid.Row="2"
                            Background="#0A000000"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            CornerRadius="3"
                            Padding="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                            <ItemsControl x:Name="FoldersList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ChipStyle}" Margin="0,0,0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Content="X"
                                                        FontSize="7"
                                                        Foreground="{StaticResource AccentLightBrush}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="4,0"
                                                        Cursor="Hand"
                                                        Tag="{Binding}"
                                                        Click="RemoveFolder_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <Button Grid.Row="3" Style="{StaticResource NavButton}"
                            Content="+ Browse Folders"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Left"
                            Click="AddFolder_Click"/>
                </Grid>

                <!-- Step 5: Websites -->
                <Grid x:Name="StepWebsites" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource StepTitle}" Text="ADD WEBSITES"/>
                    <TextBlock Grid.Row="1" Style="{StaticResource StepDesc}"
                               Text="Websites to open in your default browser."/>
                    <Border Grid.Row="2"
                            Background="#0A000000"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            CornerRadius="3"
                            Padding="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                            <ItemsControl x:Name="WebsitesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ChipStyle}" Margin="0,0,0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="9" Foreground="{StaticResource TextDimBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Content="X"
                                                        FontSize="7"
                                                        Foreground="{StaticResource AccentLightBrush}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="4,0"
                                                        Cursor="Hand"
                                                        Tag="{Binding}"
                                                        Click="RemoveWebsite_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <Grid Grid.Row="3" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="WebsiteInput"
                                 Style="{StaticResource WizInput}"
                                />
                        <Button Grid.Column="1"
                                Style="{StaticResource NavButton}"
                                Content="+ Add"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Margin="6,0,0,0"
                                Click="AddWebsite_Click"/>
                    </Grid>
                </Grid>

                <!-- Step 6: Review -->
                <Grid x:Name="StepReview" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource StepTitle}" Text="REVIEW &amp; LAUNCH"/>
                    <TextBlock Grid.Row="1" Style="{StaticResource StepDesc}"
                               Text="Here are your workspaces. You can edit them anytime in the config file."/>
                    <Border Grid.Row="2"
                            Background="#0A000000"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            CornerRadius="3"
                            Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                            <ItemsControl x:Name="ModesPreviewList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ChipStyle}" Margin="0,0,0,4" Padding="8,6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="{Binding AccentBrush}"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="12" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Grid>
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Description}"
                                                           FontSize="8" Foreground="{StaticResource TextDimBrush}"
                                                           Margin="14,2,0,0"/>
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Summary}"
                                                           FontSize="7" Foreground="{StaticResource TextMutedBrush}"
                                                           Margin="14,4,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Style="{StaticResource NavButton}"
                                Content="+ Add Another Mode"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Click="AddMode_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Footer / Navigation -->
            <Border Grid.Row="2"
                    Background="#12000000"
                    CornerRadius="0,0,8,8"
                    Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="StatusBar"
                               FontSize="7"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            x:Name="BackButton"
                            Style="{StaticResource NavButton}"
                            Content="Back"
                            Foreground="{StaticResource TextDimBrush}"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="Back_Click"/>
                    <Button Grid.Column="2"
                            x:Name="NextButton"
                            Style="{StaticResource PrimaryButton}"
                            Content="Next"
                            Foreground="#0A0A0A"
                            Click="Next_Click"/>
                    <Button Grid.Column="2"
                            x:Name="FinishButton"
                            Style="{StaticResource PrimaryButton}"
                            Content="Launch ARCYN"
                            Foreground="#0A0A0A"
                            Visibility="Collapsed"
                            Click="Finish_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
