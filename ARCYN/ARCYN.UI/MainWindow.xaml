<Window x:Class="ARCYN.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="920"
        Height="490"
        WindowStyle="None"
        Background="#FF0A0A0A"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="{StaticResource UIFont}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <DataTemplate x:Key="ModeCardTemplate">
                    <Button Style="{StaticResource WorkstationPanelStyle}"
                            Click="ModeButton_Click"
                            Tag="{Binding}"
                            MinHeight="84"
                            Margin="0">
                        <Button.ContextMenu>
                            <ContextMenu Background="#F0080808"
                                         BorderThickness="1"
                                         BorderBrush="{StaticResource BorderSubtleBrush}"
                                         FontFamily="{StaticResource UIFont}"
                                         FontSize="9"
                                         Foreground="{StaticResource TextPrimaryBrush}">
                                <MenuItem Header="Edit" Click="MenuEdit_Click"/>
                                <MenuItem Header="Duplicate" Click="MenuDuplicate_Click"/>
                                <Separator Background="{StaticResource BorderSubtleBrush}" Height="1" Margin="4,2"/>
                                <MenuItem Header="Move Up" Click="MenuMoveUp_Click"/>
                                <MenuItem Header="Move Down" Click="MenuMoveDown_Click"/>
                                <Separator Background="{StaticResource BorderSubtleBrush}" Height="1" Margin="4,2"/>
                                <MenuItem Header="Delete" Click="MenuDelete_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{Binding AccentBarBrush}" CornerRadius="2,0,0,2">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding IndexLabel}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="#D8F08080"
                                       HorizontalAlignment="Center" />
                            <Ellipse Width="2"
                                     Height="2"
                                     Margin="0,2,0,0"
                                     Fill="{StaticResource AccentBrightBrush}"
                                     Effect="{StaticResource GlowAccentSharp}" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="1" Margin="10,5,10,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextBrightBrush}" />
                                <TextBlock Text="{Binding Description}"
                                           FontSize="8"
                                           Foreground="{StaticResource TextDimBrush}"
                                           Margin="0,1,0,0" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    Background="#18000000"
                                    Padding="6,1"
                                    CornerRadius="2"
                                    Margin="0,0,6,0">
                                <TextBlock Text="{Binding ProcessLabel}"
                                           FontSize="7"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding LaunchCountLabel}"
                                       FontSize="7"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding Targets}"
                                      Margin="0,6,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,5,3"
                                            Padding="5,1"
                                            CornerRadius="2"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            Background="#14000000">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text=">"
                                                       FontSize="7"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Margin="0,0,3,0" />
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       FontSize="7"
                                                       Foreground="{StaticResource TextDimBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Rectangle Width="60"
                                           Height="1"
                                           Fill="{StaticResource BorderSubtleBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding LastLaunchLabel}"
                                           FontSize="7"
                                           Margin="6,0,0,0"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock Text="{Binding LastOutcomeLabel}"
                                           FontSize="7"
                                           Margin="6,0,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Opacity="0.6" />
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ShortcutHint}"
                                       FontSize="7"
                                       Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMutedBrush}" />

                            <TextBlock Grid.Column="2"
                                       Text="LAUNCH"
                                       FontSize="8"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                        </Grid>
                    </Grid>
                </Grid>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Transparent" MouseDown="RootGrid_MouseDown">
        <Canvas x:Name="ParticleCanvas" IsHitTestVisible="False" />
        <Rectangle x:Name="AmbientGlow" Style="{StaticResource AmbientGlow}" />
        <Rectangle x:Name="StartupFlash" Fill="#D64545" Opacity="0" IsHitTestVisible="False" />
        <Rectangle x:Name="ScanlinesOverlay" Style="{StaticResource Scanlines}" />
        <Rectangle Style="{StaticResource Vignette}" />
        <Canvas x:Name="TrailCanvas" IsHitTestVisible="False" Panel.ZIndex="100" />

        <Grid x:Name="ShellHost" Margin="16,12">
            <Border x:Name="MainBorder"
                    CornerRadius="9"
                    Width="6"
                    Height="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#D6080808"
                    BorderThickness="1"
                    BorderBrush="{StaticResource BorderGlowBrush}"
                    Effect="{StaticResource GlowAccent}">
                <Grid>
                    <Grid x:Name="BootOverlay" Margin="16,12" Opacity="0" IsHitTestVisible="False" Panel.ZIndex="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="+-- [BOOT]: ARCYN --"
                                       FontSize="9"
                                       Foreground="{StaticResource TextDimBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="-- v1.0.0 --+"
                                       FontSize="9"
                                       Foreground="{StaticResource TextDimBrush}"
                                       VerticalAlignment="Center" />
                            <Rectangle Grid.Column="1"
                                       Height="1"
                                       Fill="{StaticResource BorderSubtleBrush}"
                                       VerticalAlignment="Center"
                                       Margin="4,0" />
                        </Grid>

                        <TextBlock x:Name="BootTitle"
                                   Grid.Row="1"
                                   FontSize="20"
                                   FontWeight="Light"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock x:Name="BootSubtitle"
                                   Grid.Row="2"
                                   FontSize="9"
                                   Foreground="{StaticResource TextDimBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,14" />

                        <Grid Grid.Row="3" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Height="2"
                                    Background="#08000000"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderSubtleBrush}">
                                <Rectangle x:Name="BootProgress"
                                           Fill="{StaticResource AccentBrightBrush}"
                                           HorizontalAlignment="Left">
                                    <Rectangle.RenderTransform>
                                        <ScaleTransform ScaleX="0" />
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Border>
                            <TextBlock x:Name="BootPercent"
                                       Grid.Column="1"
                                       FontSize="9"
                                       Foreground="{StaticResource TextDimBrush}"
                                       Margin="10,0,0,0"
                                       Text="0%" />
                        </Grid>

                        <TextBlock x:Name="BootLog"
                                   Grid.Row="4"
                                   FontSize="9"
                                   FontWeight="Light"
                                   Foreground="{StaticResource TextDimBrush}"
                                   Margin="0,0,0,8"
                                   LineHeight="15" />

                        <Grid Grid.Row="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="BootReady"
                                       Grid.Column="0"
                                       FontSize="11"
                                       FontWeight="Light"
                                       Foreground="{StaticResource AccentBrightBrush}"
                                       Opacity="0"
                                       Text="SYSTEM READY"
                                       HorizontalAlignment="Left" />
                            <TextBlock x:Name="BootCpu"
                                       Grid.Column="1"
                                       FontSize="8"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="CPU: --%"
                                       Margin="0,0,10,0" />
                            <TextBlock x:Name="BootRam"
                                       Grid.Column="2"
                                       FontSize="8"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="RAM: --%" />
                        </Grid>
                    </Grid>

                    <Grid x:Name="MainHUD" Opacity="0" Margin="8" Panel.ZIndex="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="16" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                CornerRadius="2"
                                Background="#12000000"
                                Padding="8,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="4"
                                         Height="4"
                                         Fill="{StaticResource AccentBrightBrush}"
                                         VerticalAlignment="Center"
                                         Effect="{StaticResource GlowAccentSoft}" />
                                <TextBlock Grid.Column="1"
                                           Text="ARCYN"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Margin="6,0,10,0"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           x:Name="ModeCountRun"
                                           FontSize="8"
                                           Margin="0,0,10,0"
                                           Foreground="{StaticResource TextDimBrush}"
                                           VerticalAlignment="Center"
                                           Text="00" />
                                <TextBlock Grid.Column="3"
                                           x:Name="PhaseLabel"
                                           FontSize="8"
                                           Margin="0,0,14,0"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Text="BOOT" />
                                <TextBlock Grid.Column="4"
                                           x:Name="HeaderCpu"
                                           FontSize="8"
                                           Margin="0,0,10,0"
                                           Foreground="{StaticResource TextDimBrush}"
                                           VerticalAlignment="Center"
                                           Text="CPU --%" />
                                <TextBlock Grid.Column="5"
                                           x:Name="HeaderRam"
                                           FontSize="8"
                                           Margin="0,0,10,0"
                                           Foreground="{StaticResource TextDimBrush}"
                                           VerticalAlignment="Center"
                                           Text="RAM --%" />
                                <TextBlock Grid.Column="6"
                                           x:Name="HeaderUptime"
                                           FontSize="8"
                                           Margin="0,0,10,0"
                                           Foreground="{StaticResource TextDimBrush}"
                                           VerticalAlignment="Center"
                                           Text="UP 00:00:00" />
                                <TextBlock Grid.Column="7"
                                           x:Name="HeaderSys"
                                           FontSize="8"
                                           FontWeight="Bold"
                                           Margin="0,0,10,0"
                                           Foreground="{StaticResource AccentBrightBrush}"
                                           VerticalAlignment="Center"
                                           Text="ONLINE" />
                                <Rectangle Grid.Column="8"
                                           Height="1"
                                           Fill="{StaticResource BorderSubtleBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="9"
                                           x:Name="TimeDisplay"
                                           FontSize="8"
                                           Foreground="{StaticResource TextDimBrush}"
                                           VerticalAlignment="Center"
                                           Text="00:00:00" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Border x:Name="ModePanel"
                                    CornerRadius="3"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    Background="#E9080808"
                                    Padding="8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Background="Transparent"
                                              BorderThickness="0">
                                    <Grid x:Name="DashboardGrid" />
                                </ScrollViewer>
                            </Border>

                            <Border x:Name="LaunchPanel"
                                    CornerRadius="3"
                                    Opacity="0"
                                    Visibility="Collapsed"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    Background="#E9080808"
                                    Padding="10">
                                 <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Header + target count + separator -->
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="▲ LAUNCH SEQUENCE"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrightBrush}"
                                                   VerticalAlignment="Center" />
                                        <Ellipse Width="4" Height="4"
                                                 Fill="{StaticResource AccentBrightBrush}"
                                                 Effect="{StaticResource GlowAccentSharp}"
                                                 Margin="6,0" VerticalAlignment="Center" />
                                        <Rectangle Grid.Column="2"
                                                   Height="1"
                                                   Fill="{StaticResource BorderSubtleBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="3"
                                                   x:Name="LaunchTargetCount"
                                                   FontSize="8"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="00 TARGETS" />
                                    </Grid>

                                    <!-- Row 1: Mode name + spinner -->
                                    <Grid Grid.Row="1" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock x:Name="LaunchModeLabel"
                                                       FontSize="22" FontWeight="Light"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="" />
                                            <TextBlock x:Name="LaunchSessionLabel"
                                                       FontSize="9" Margin="0,2,0,0"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       Text="" />
                                        </StackPanel>
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <Ellipse Width="36" Height="36"
                                                     Stroke="{StaticResource BorderSubtleBrush}"
                                                     StrokeThickness="0.5" Opacity="0.3" />
                                            <Viewbox Width="28" Height="28">
                                                <Canvas Width="28" Height="28">
                                                    <Path x:Name="SpinnerArc"
                                                          Stroke="{StaticResource AccentBrightBrush}"
                                                          StrokeThickness="2.5"
                                                          StrokeEndLineCap="Round"
                                                          StrokeStartLineCap="Round"
                                                          Width="28" Height="28"
                                                          Stretch="Uniform"
                                                          Data="M 3,14 A 11,11 0 1,1 25,14"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform x:Name="SpinnerRotation" />
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Canvas>
                                            </Viewbox>
                                        </Grid>
                                    </Grid>

                                    <!-- Row 2: Target feed -->
                                    <Border Grid.Row="2" CornerRadius="2"
                                            Background="#0A000000"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            Padding="8,6" MinHeight="56">
                                        <ScrollViewer x:Name="LaunchFeedScroll"
                                                      VerticalScrollBarVisibility="Hidden"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Background="Transparent">
                                            <TextBlock x:Name="LaunchFeedText"
                                                       FontSize="8"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       LineHeight="14" />
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Row 3: Telemetry strip -->
                                    <Grid Grid.Row="3" Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="LaunchCpu"
                                                   Grid.Column="0"
                                                   FontSize="8"
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   Text="CPU --%" />
                                        <TextBlock x:Name="LaunchRam"
                                                   Grid.Column="1"
                                                   FontSize="8"
                                                   Margin="10,0,0,0"
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   Text="RAM --%" />
                                        <TextBlock x:Name="LaunchStatus"
                                                   Grid.Column="2"
                                                   FontSize="9"
                                                   FontWeight="Medium"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="Launching" />
                                        <TextBlock x:Name="LaunchProgressText"
                                                   Grid.Column="3"
                                                   FontSize="8"
                                                   Margin="12,0,0,0"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="PROC 00/00" />
                                    </Grid>

                                    <!-- Row 4: Segmented progress bar -->
                                    <Border Grid.Row="4" Height="6" CornerRadius="2"
                                            Background="#06000000"
                                            BorderThickness="0.5"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            Padding="1">
                                        <Grid>
                                            <Rectangle Fill="{StaticResource BorderSubtleBrush}"
                                                       RadiusX="1" RadiusY="1" Opacity="0.3" />
                                            <Rectangle Fill="{StaticResource AccentBrush}"
                                                       RadiusX="1" RadiusY="1"
                                                       HorizontalAlignment="Left"
                                                       RenderTransformOrigin="0,0.5">
                                                <Rectangle.RenderTransform>
                                                    <ScaleTransform x:Name="LaunchProgressScale" ScaleX="0" />
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                    </Border>

                                    <!-- Row 5: Footer -->
                                    <Grid Grid.Row="5" Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ESC aborts · targets launch sequentially"
                                                   FontSize="7"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Opacity="0.5" />
                                        <TextBlock Grid.Column="1"
                                                   x:Name="LaunchRecent"
                                                   FontSize="7"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border CornerRadius="2"
                                    Background="#12000000"
                                    Padding="6,2"
                                    Margin="0,0,4,0">
                                <TextBlock x:Name="RuntimeStrip"
                                           FontSize="7"
                                           Foreground="{StaticResource TextDimBrush}"
                                           Text="RUNTIME 00:00:00" />
                            </Border>

                            <Border Grid.Column="1"
                                    CornerRadius="2"
                                    Background="#12000000"
                                    Padding="6,2"
                                    Margin="2,0,2,0">
                                <TextBlock x:Name="ProcessStrip"
                                           FontSize="7"
                                           Foreground="{StaticResource TextDimBrush}"
                                           Text="PROC 00  -  ACTIVE STANDBY" />
                            </Border>

                            <Border Grid.Column="2"
                                    CornerRadius="2"
                                    Background="#12000000"
                                    Padding="6,2"
                                    Margin="4,0,0,0">
                                <TextBlock x:Name="SystemStrip"
                                           FontSize="7"
                                           Foreground="{StaticResource TextDimBrush}"
                                           Text="SYS ONLINE  -  HUD STABLE" />
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="FooterHint"
                                       Grid.Column="0"
                                       FontSize="7"
                                       Foreground="{StaticResource TextDimBrush}"
                                       Opacity="0.45"
                                       VerticalAlignment="Center"
                                       Text="[1-3] select  -  ENTER launch  -  ESC close" />
                            <TextBlock x:Name="FooterIdle"
                                       Grid.Column="1"
                                       FontSize="7"
                                       Foreground="{StaticResource TextDimBrush}"
                                       Opacity="0.30"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
