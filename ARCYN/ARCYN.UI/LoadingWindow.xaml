<Window x:Class="ARCYN.UI.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ARCYN.UI"
        Title="ARCYN"
        Width="800" Height="480"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource UIFont}">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="20">
        <Rectangle Style="{StaticResource Scanlines}" />
        <Rectangle Style="{StaticResource Vignette}" />

        <Border CornerRadius="8" Background="#F0080808"
                BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}"
                Effect="{StaticResource GlowTealSoft}">
            <Grid Margin="36,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="ModeLabel" Grid.Row="0" FontSize="10"
                           Foreground="{StaticResource TextDimBrush}"
                           HorizontalAlignment="Center" />

                <Viewbox Grid.Row="1" Width="32" Height="32"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Canvas Width="32" Height="32">
                        <Path x:Name="SpinnerArc"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="2.5"
                              StrokeEndLineCap="Round"
                              StrokeStartLineCap="Round"
                              Width="32" Height="32"
                              Stretch="Uniform"
                              Data="M 3,16 A 13,13 0 1,1 29,16"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotation" />
                            </Path.RenderTransform>
                        </Path>
                    </Canvas>
                </Viewbox>

                <Border Grid.Row="2"
                        Background="#08000000"
                        CornerRadius="4"
                        BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}"
                        Padding="16,10"
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" x:Name="CpuText"
                                   FontSize="10"
                                   Foreground="{StaticResource TextDimBrush}"
                                   Margin="0,0,14,0" />
                        <TextBlock Grid.Column="1" x:Name="RamText"
                                   FontSize="10"
                                   Foreground="{StaticResource TextDimBrush}"
                                   Margin="0,0,14,0" />
                        <TextBlock Grid.Column="2" x:Name="StatusText"
                                   FontSize="10"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <Rectangle x:Name="ProgressBar" Grid.Row="3" Height="1"
                           Fill="{StaticResource TealBrush}" Opacity="0"
                           HorizontalAlignment="Stretch" Margin="0,8,0,0"
                           RenderTransformOrigin="0,0.5">
                    <Rectangle.RenderTransform>
                        <ScaleTransform ScaleX="0" />
                    </Rectangle.RenderTransform>
                </Rectangle>
            </Grid>
        </Border>
    </Grid>
</Window>