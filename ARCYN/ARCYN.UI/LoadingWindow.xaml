<Window x:Class="ARCYN.UI.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ARCYN.UI"
        Title="ARCYN"
        Width="800" Height="480"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource UIFont}">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="20">
        <Rectangle Style="{StaticResource Scanlines}" />

        <Border CornerRadius="8" Background="#F0080808"
                BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}">
            <Grid Margin="28,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Viewbox Grid.Row="0" Width="40" Height="40"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Canvas Width="40" Height="40">
                        <Path x:Name="SpinnerArc"
                              Stroke="{StaticResource TextSecondaryBrush}"
                              StrokeThickness="2.5"
                              StrokeEndLineCap="Round"
                              StrokeStartLineCap="Round"
                              Width="40" Height="40"
                              Stretch="Uniform"
                              Data="M 4,20 A 16,16 0 1,1 36,20"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotation" />
                            </Path.RenderTransform>
                        </Path>
                    </Canvas>
                </Viewbox>

                <Border Grid.Row="1"
                        Background="#08000000"
                        CornerRadius="4"
                        BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}"
                        Padding="16,10"
                        Margin="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" x:Name="CpuText"
                                   FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}"
                                   Margin="0,0,12,0" />
                        <TextBlock Grid.Column="1" x:Name="RamText"
                                   FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}"
                                   Margin="0,0,12,0" />
                        <TextBlock Grid.Column="2" x:Name="StatusText"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
