      "folders": []
    },
    {
      "name": "BROWSE",
      "description": "Research and references",
      "accent": "#45A0D6",
      "apps": [],
      "websites": [
        "https://www.wikipedia.org",
        "https://news.ycombinator.com",
        "https://stackoverflow.com"
      ],
      "folders": []
    },
    {
      "name": "CREATE",
      "description": "Design and media workspace",
      "accent": "#D6A045",
      "apps": ["mspaint"],
      "websites": ["https://www.pinterest.com"],
      "folders": []
    }
  ]
}
